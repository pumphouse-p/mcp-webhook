# MCP Server Authentication Configuration

# Enable/disable server authentication
MCP_AUTH_ENABLED=false

# Authentication type: "api_key" or "basic"
MCP_AUTH_TYPE=api_key

# API Key authentication (comma-separated for multiple keys)
MCP_API_KEYS=your-secret-key-1,your-secret-key-2

# Basic authentication credentials
MCP_USERNAME=admin
MCP_PASSWORD=your-secure-password
