# Server Configuration
PORT=3000
HOST=0.0.0.0

# MCP Server Authentication Configuration
# Enable/disable server authentication
MCP_AUTH_ENABLED=false

# Authentication type: "api_key" or "basic"
MCP_AUTH_TYPE=api_key

# API Key authentication (comma-separated for multiple keys)
MCP_API_KEYS=your-secret-key-1,your-secret-key-2

# Basic authentication credentials
MCP_USERNAME=admin
MCP_PASSWORD=your-secure-password

# Logging Configuration (MCP-over-HTTP mode)
# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Enable/disable request logging (default: true)
LOG_REQUESTS=true

# Enable/disable response logging (default: true)
LOG_RESPONSES=true

# Enable/disable body logging - can be verbose (default: false)
LOG_BODIES=false

# Pretty print JSON logs for readability (default: false)
LOG_PRETTY=false

# Maximum body length to log in characters (default: 1000)
LOG_MAX_BODY_LENGTH=1000
